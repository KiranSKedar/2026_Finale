JAVA soln:
class Solution {
    public static int getMaxArea(int arr[]) {
        
        int n = arr.length;
        
        Stack<Integer> s = new Stack<>();
        Stack<Integer> s1 = new Stack<>();
        
        ArrayList<Integer> nsl = new ArrayList<Integer>();
        ArrayList<Integer> nsr = new ArrayList<Integer>();
        
        ArrayList<Integer> area = new ArrayList<Integer>();
        
        // your code here
        
        // nsl
        
        for(int i = 0; i < n; i++){
            if(s.isEmpty()){
                nsl.add(-1);
            }else{
                if(arr[s.peek()] < arr[i]){
                    nsl.add(s.peek());
                }else{
                    while(s.size()>0 && arr[s.peek()]>=arr[i]){
                        s.pop();
                    }
                    if(s.size()==0){
                        nsl.add(-1);
                    }else{
                        nsl.add(s.peek());
                    }
                }
            }
            s.push(i);
        }
        for(int i = 0; i<n; i++){
            
                nsl.set(i,i - nsl.get(i));
            
            
        }
        
        // nsr
        for(int i = n - 1; i >= 0; i--){
            if(s1.isEmpty()){
                nsr.add(n);
            }else{
                if(arr[s1.peek()] < arr[i]){
                    nsr.add(s1.peek());
                }else{
                    while(s1.size()>0 && arr[s1.peek()]>=arr[i]){
                        s1.pop();
                    }
                    if(s1.size()==0){
                        nsr.add(n);
                    }else{
                        nsr.add(s1.peek());
                    }
                }
            }
            s1.push(i);
        }
        
        Collections.reverse(nsr);
        
        for(int i = 0; i<n; i++){
            
                nsr.set(i,nsr.get(i)-i);
            
            
        }
        
        for(int i = 0; i<n; i++){
            int width = nsr.get(i)+nsl.get(i)-1;
            area.add(width*arr[i]);
        }
        return Collections.max(area);
        
    }
}
