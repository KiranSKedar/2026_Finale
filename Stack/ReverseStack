public static void reverseStack(Stack<Integer> st){
        Stack<Integer> s1=new Stack<>();
        Stack<Integer> s2=new Stack<>();
        while(st.size()>0){
            s1.push(st.pop());
        }

        while(s1.size()>0){
            s2.push(s1.pop());
        }

        while(s2.size()>0){
            st.push(s2.pop());
        }

        System.out.println(st);
    }
