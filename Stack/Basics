package com.eazybytes.backend.Stack;

import java.util.Stack;

public class BasicsOfStack {

    public static void moveStackInSameOrder(Stack<Integer> s){
        Stack<Integer> rt=new Stack<>();
        while(s.size()>0){
            int x=s.peek();
            rt.push(x);
            s.pop();
        }
        System.out.println("Reverse order: "+rt);
    }
    public static void main(String[] args) {
        Stack<Integer> st=new Stack<>();
        st.push(1);
        st.push(2);
        st.push(3);
        st.push(4);
        st.push(5);

        System.out.println(st.peek());

        System.out.println(st);

        st.pop();

        System.out.println(st);

        System.out.println("Stack size is: "+st.size());
         moveStackInSameOrder(st);
    }
}
