class MinStack {

    Stack<Integer> st=new Stack<>();
    Stack<Integer> mini=new Stack<>();
    public MinStack() {
        
    }
    
    public void push(int val) {
        if(st.isEmpty()){
            mini.push(val);
        }else if(mini.peek()>val){
            mini.push(val);
        }else{
            mini.push(mini.peek());
        }
        st.push(val);
        
    }
    
    public void pop() {
        mini.pop();
        st.pop();
    }
    
    public int top() {
      return  st.peek();
    }
    
    public int getMin() {
        return mini.peek();
    }
}

