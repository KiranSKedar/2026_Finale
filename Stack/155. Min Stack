class MinStack {

    Stack<Long> st = new Stack<>();
    long min;

    public void push(int val) {
        long x = val;

        if(st.isEmpty()){
            st.push(x);
            min = x;
        }
        else if(x >= min){
            st.push(x);
        }
        else{
            st.push(2*x - min);
            min = x;
        }
    }
    
    public void pop() {
        if(st.isEmpty()) return;

        long top = st.peek();
        st.pop();

        if(top < min){
            min = 2*min - top;
        }
    }
    
    public int top() {
        if(st.isEmpty()) return -1;

      if(st.peek() >= min) return st.peek().intValue();
else return (int)min;
    }
    
    public int getMin() {
        if(st.isEmpty()) return -1;
        return (int)min;
    }
}
