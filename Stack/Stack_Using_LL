package com.eazybytes.backend.Stack;

class NodeLL{
    int val;
    NodeLL next;
    NodeLL(int val){
        this.val=val;
    }
}
class Stac{
    NodeLL head=null;
    int size=0;

    void push(int x){
        NodeLL temp=new NodeLL(x);
        temp.next=head;
        head=temp;
        size++;
    }

//    void display(NodeLL head){
//NodeLL temp=head;
//        if(head==null) return;
//        display();
//
//    }
    void displayRev(){
        NodeLL t=head;
        while(t!=null){
            System.out.print(t.val+" ");
            t=t.next;
        }
        System.out.println();

    }
    int size(){
        return size;
    }

    int pop(){
        if(head==null){
            System.out.println("Stack is empty");
            return -1;
        }
        int t=head.val;
        head=head.next;
        return t;
    }
    int peek(){
        return head.val;
    }
}
public class StackUseLL {
    public static void main(String[] args) {
        Stac s=new Stac();
        s.push(4);
        s.push(3);
        s.push(2);
        s.push(1);
        System.out.println("Peek Element: "+s.peek());
        System.out.println("Stack Elements");
//        s.display();

        System.out.println("Stack Size: "+s.size());
        System.out.println("Popped element: "+s.pop());
        System.out.println("Stack Elements after poppping");
//        s.display();
    }
}
