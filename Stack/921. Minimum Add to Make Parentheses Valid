https://leetcode.com/problems/minimum-add-to-make-parentheses-valid/description/

class Solution {
    public int minAddToMakeValid(String s) {

        int n=s.length();
        int cnt=0;
        Stack<Character> st=new Stack<>();
        for(int i=0;i<n;i++){
            char ch=s.charAt(i);
            if(ch=='(')
            st.push(ch);
            else if(ch==')' && !st.isEmpty())
            st.pop();
            else cnt++;

        }
        return st.size()+cnt;
        
    }
}
