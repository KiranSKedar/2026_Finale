
//Nearest Greater to left
class Solution {

    public ArrayList<Integer> calculateSpan(int price[], int n) {

        // creating ArrayList to store result
        ArrayList<Integer> v = new ArrayList<>();

        // creating stack of pairs
        // pair -> {price, index}
        Stack<int[]> s = new Stack<>();

        for (int i = 0; i < n; i++) {

            // when stack is empty return -1
            if (s.size() == 0) {

                v.add(-1);
            }

            // when stack has element and stack top price
            // is greater than current price
            else if (s.size() > 0 && s.peek()[0] > price[i]) {

                // add stack top index into result
                v.add(s.peek()[1]);
            }

            // when stack has element and stack top price
            // is smaller or equal to current price
            else if (s.size() > 0 && s.peek()[0] <= price[i]) {

                // remove elements until stack becomes empty
                // or we find greater price
                while (s.size() > 0 && s.peek()[0] <= price[i]) {

                    // remove smaller element
                    s.pop();
                }

                // if stack becomes empty
                if (s.size() == 0) {

                    // no greater element exists
                    v.add(-1);
                }

                // if greater element exists
                else {

                    // add stack top index into result
                    v.add(s.peek()[1]);
                }
            }

            // push current price and index into stack
            s.push(new int[]{price[i], i});
        }

        // subtract current index from stored index
        // to calculate stock span
        for (int i = 0; i < v.size(); i++) {

            v.set(i, i - v.get(i));
        }

        // return final result
        return v;
    }
}
