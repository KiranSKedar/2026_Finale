class Solution {
    public ArrayList<Integer> nextLargerElement(int[] arr) {
        // code here
        ArrayList<Integer> an=new ArrayList<Integer>();
        
        
        
        int n=arr.length;
        
        int[] ans=new int[n];
        ans[n-1]=-1;
        
        Stack<Integer> st=new Stack<>();
        st.push(arr[n-1]);
        
        for(int i=n-2;i>=0;i--){
            while(!st.isEmpty() && st.peek()<=arr[i]){
                st.pop();
            }
            if(st.isEmpty()) ans[i]=-1;
            else ans[i]=st.peek();
            st.push(arr[i]);
        }
        
        for(int i=0;i<n;i++){
            an.add(ans[i]);
        }
        return an;
        
    }
}


