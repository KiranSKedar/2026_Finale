import java.util.Stack;

class StockSpanner {

    Stack<Integer> st; // store indices
    int[] prices;
    int i;

    public StockSpanner() {
        st = new Stack<>();
        prices = new int[10000]; // enough size
        i = 0;
    }

    public int next(int price) {

        prices[i] = price;

        // same logic as your code
        while (!st.isEmpty() && prices[st.peek()] <= price) {
            st.pop();
        }

        int span;
        if (st.isEmpty()) {
            span = i + 1;
        } else {
            span = i - st.peek();
        }

        st.push(i);
        i++;

        return span;
    }
}

