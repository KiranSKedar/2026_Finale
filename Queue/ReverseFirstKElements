int k = 3;
int n = q.size();
Stack<Integer> st = new Stack<>();

// Step 1: push first k elements into stack
for(int i = 0; i < k; i++){
    st.push(q.remove());
}

// Step 2: add them back (reversed)
while(!st.isEmpty()){
    q.add(st.pop());
}

// Step 3: move remaining (n - k) elements to back
for(int i = 0; i < n - k; i++){
    q.add(q.remove());
}

System.out.println(q);
