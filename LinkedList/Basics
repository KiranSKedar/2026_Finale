package com.eazybytes.backend.LinkedList;

public class Basics {

    public static class Node{
        int data;
        Node next;

        Node(int data){
            this.data=data;

        }
    }
    public static void main(String[] args) {
        

        Node a=new Node(4);
        Node b=new Node(5);
        Node c=new Node(6);
        Node d=new Node(7);
        
        a.next=b;
        b.next=c;
        c.next=d;
        
        System.out.println(a.data);
        System.out.println(a.next.data);
        
    }
}
