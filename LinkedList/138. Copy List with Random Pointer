class Solution {
    public Node copyRandomList(Node head) {

        HashMap<Node, Node>mp=new HashMap<>();

        Node ans=new Node(100);
        
        Node i=ans;
        Node temp=head;
        while(temp!=null){
            Node t=new Node(temp.val);
            mp.put(temp,t);
            i.next=t;
            temp=temp.next;
            i=i.next;
        }

        temp=head;
        i=ans.next;
        while(temp!=null){
            
            i.random=mp.get(temp.random);
            temp=temp.next;
            i=i.next;
        }

        return ans.next;
        
    }
}
