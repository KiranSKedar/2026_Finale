class Solution {
    public boolean check(int[] nums) {

        int n=nums.length;
        int[] temp=nums.clone();
        Arrays.sort(temp);

        for(int offset=0;offset<n;offset++){
            boolean flag=true;
            for(int i=0;i<n;i++){
                if(nums[(offset+i)%n]!=temp[i]){
                    flag=false;
                    break;
                }
            }
            if(flag==true) return true;
        }

      return false;
        
    }
}


