class Solution {
    public void rotate(int[] nums, int k) {

        int n=nums.length;
         k=k%n;
        int[] temp=new int[k];
        int idx=0;
        for(int i=n-k;i<n;i++){
            temp[idx++]=nums[i];
        }
        for(int i=n-k-1;i>=0;i--){
            nums[i+k]=nums[i];
        }
        for(int i=0;i<k;i++){
            nums[i]=temp[i];
        }


        
    }
}

*************************************************************
For rotating an array to the right by k positions, the correct steps are:

Reverse the entire array
Reverse the first k elements
Reverse the remaining n-k elements


Right Rotate → Whole → First k → Rest
Left Rotate → First k → Rest → Whole

class Solution {

    void reverseArray(int[] nums,int i,int j){
        while(i<j){
            int temp=nums[i];
            nums[i]=nums[j];
            nums[j]=temp;
            i++;
            j--;
        }
    }
    public void rotate(int[] nums, int k) {

        int n=nums.length;
        k=k%n;
         reverseArray(nums,0,n-1);
        reverseArray(nums,0,k-1);
        reverseArray(nums,k,n-1);
       
       


        
    }
}
