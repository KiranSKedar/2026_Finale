https://leetcode.com/problems/fibonacci-number/
Recursion + Memoation
class Solution {

    public int fibHelper(int n,int dp[]){
        if(n<2) return n;
        if(dp[n]!=0) return dp[n];
        int ans = fibHelper(n-1,dp)+fibHelper(n-2,dp);
        dp[n]=ans;
        return ans;
    }
    public int fib(int n) {

        int dp[]=new int[n+1];
        return fibHelper(n,dp);
        
    }
}


