Friends Pairing Problem
https://www.geeksforgeeks.org/problems/friends-pairing-problem5425/1

class Solution {
    public long countFriendsPairings(int n) {
        
        if(n<=2) return n;
        
       return countFriendsPairings(n-1)+ (n-1)* countFriendsPairings(n-2);
        // code here
        
    }
}
