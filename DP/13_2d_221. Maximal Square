https://leetcode.com/problems/maximal-square/description/

class Solution {
    public int maximalSquare(char[][] matrix) {


        int n=matrix.length;
        int m=matrix[0].length;

        int[][] mat2=new int[n][m];

        int ans=Integer.MIN_VALUE;

        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(matrix[i][j]=='0')
                mat2[i][j]=0;
                else
                mat2[i][j]=1;
            }
        }

        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(mat2[i][j]==0) continue;
                if(i>0 && j>0)
               mat2[i][j]+=Math.min(Math.min(mat2[i-1][j-1],mat2[i][j-1]),mat2[i-1][j]);

                ans=Math.max(ans,mat2[i][j]);
            }
        }

        return ans*ans;
        
    }
}
