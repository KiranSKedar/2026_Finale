class Solution {
    public List<Integer> findClosestElements(int[] arr, int k, int x) {
        List<Integer>ans=new ArrayList<>();

        int n=arr.length;

    PriorityQueue<int[]> q =
    new PriorityQueue<>(
        (a,b) -> {

            if(b[0] == a[0]){
                return b[1] - a[1];
            }

            return b[0] - a[0];
        }
    );
        for(int i=0;i<n;i++){
            q.add(new int[]{Math.abs(x-arr[i]),arr[i]});

            if(q.size()>k){
                q.poll();
            }
        }

        while(!q.isEmpty()){

            ans.add(q.peek()[1]);
            q.poll();
        }

        Collections.sort(ans);

        return ans;
    }
}
