package com.eazybytes.backend.Recursion;

public class GCD {

    static void getGcd(int x,int y){

       while(x%y!=0){
          int rem=x%y;
           x=y;
           y=rem;
       }
       System.out.println(y);
    }

    static int gcdEucledian(int x,int y){
        if(y==0) return x;
        return gcdEucledian(y,x%y);
    }

    public static void main(String[] args) {
        int x=24;
        int y=15;
        getGcd(x,y);

       int ans= gcdEucledian(x,y);

       System.out.print(ans);
    }
}
