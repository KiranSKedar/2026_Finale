package com.eazybytes.backend.Recursion;

public class RemoveOccString {

    static String removeOccOfA2(String s){
        if(s.length()==0) return "";

        String smallAns=removeOccOfA2(s.substring(1));
        char ch=s.charAt(0);
        if(ch!='a'){
            return ch+smallAns;
        }else{
            return smallAns;
        }
    }

    static String removeOccOfA(String s,char c,int i,int n){
        if(i==n) return "";
        String smallAns=removeOccOfA(s,c,i+1,n);
        char ch=s.charAt(i);
        if(ch!=c){
            return ch+smallAns;
        }else{
            return smallAns;
        }
    }

    public static void main(String[] args) {
        String s= "abcacaaxacvfa";
        int n=s.length();
        String ans=removeOccOfA(s,'a',0,n);

        System.out.println(ans);

        String ans2=removeOccOfA2(s);

        System.out.println("By second method  "+ans2);
    }
}
