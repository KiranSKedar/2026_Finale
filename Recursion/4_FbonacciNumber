package com.eazybytes.backend.Recursion;

public class Fibonacci {
    static int getFib(int n){
        if(n==0 || n==1) return n;

        return getFib(n-1)+getFib(n-2);
    }
    public static void main(String[] args) {
        int n=10;
       int fibNum= getFib(n);
       System.out.print(fibNum);
    }
}
