class Solution {


    public double recPow(double x,int n){
        if(n==0) return 1;
        double call=recPow(x,n/2);

        if(n%2==0) return call*call;
        else return x*call*call;
    }
    public double myPow(double x, int n) {
         if(n<0) return 1/recPow(x,-n);
       return recPow(x,n);
       

        
        

        

        
