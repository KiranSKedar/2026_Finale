package com.eazybytes.backend.Recursion;

public class Power {

    static int calPower(int a,int b){
        if(b==0) return 1;

        return a*calPower(a,b-1);
    }
    public static void main(String[] args) {
        int ans=calPower(5,4);
        System.out.print(ans);
    }
}


