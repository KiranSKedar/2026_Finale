package com.eazybytes.backend.Recursion;

public class SumN {

    static int findSum(int[]a,int idx,int n){
        if(idx==n)return 0;

        return a[idx]+findSum(a,idx+1,n);
    }

    public static void main(String[] args) {
        int a[]={1,2,3,4,5};
        int n=a.length;
        int sum=findSum(a,0,n);

        System.out.print(sum);
    }
}
