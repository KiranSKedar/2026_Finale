package com.eazybytes.backend.Recursion;

public class FindMaximum {

    static int getMaximum(int a[],int idx,int length){
        if(idx==length-1){
            return a[idx];
        }

        return Math.max(a[idx],getMaximum(a,idx+1,length));
    }
    public static void main(String[] args) {
        int a[]={1,2,3,4,5,67,100,1000,2000};
        int n=a.length;
        int maxi=getMaximum(a,0,n);


        System.out.print(maxi);
    }
}
