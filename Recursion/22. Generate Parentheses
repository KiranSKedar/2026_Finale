https://leetcode.com/problems/generate-parentheses/description/


class Solution {

    public static void helper(String s,int l,int r,int n,List<String>ans){

        if(s.length()==2*n){
            ans.add(s);
            return;
        }
        if(l<n) helper(s+"(",l+1,r,n,ans);

        if(r<l) helper(s+")",l,r+1,n,ans);
    }
    public List<String> generateParenthesis(int n) {

        List<String> ans=new ArrayList<String>();

        helper("",0,0,n,ans);

        return ans;
        
    }
}
