class Solution {

    private int sumDigits(int n) {
        if (n == 0) {
            return 0;
        }

        return n % 10 + sumDigits(n / 10);
    }

    public int addDigits(int num) {

        // already a single digit
        if (num >= 0 && num <= 9) {
            return num;
        }

        int sum = sumDigits(num);

        return addDigits(sum);
    }
}
