package com.eazybytes.backend.Recursion;

public class PrintNtooneNums {

    static void recPrintNums(int n){
        if(n==1)
        {
            System.out.print(1+" ");
            return;
        }
        System.out.print(n+" ");
        recPrintNums(n-1);

    }
    public static void main(String[] args) {
        int n=5;
        recPrintNums(n);
    }
}
