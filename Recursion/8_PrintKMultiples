package com.eazybytes.backend.Recursion;

public class FirstKMultiples {

    static void printMultiples(int n, int k){
        if(k==1){
            System.out.print(n+" ");
            return;
        }
        printMultiples(n,k-1);
        System.out.print(n*k+" ");
    }
    public static void main(String[] args) {
        int n=5;
        int k=5;

        printMultiples(n,k);
    }
}
