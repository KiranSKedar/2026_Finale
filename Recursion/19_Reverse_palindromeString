package com.eazybytes.backend.Recursion;

public class ReverseString {

    static String reverseString(String s,int i){
        if(i==s.length()){
            return "";
        }
        String smallAns=reverseString(s,i+1);

        return smallAns+s.charAt(i);
    }

    static boolean isPal(String s,int l,int r){
        if(l>=r) return true;

        return (s.charAt(l)==s.charAt(r) && isPal(s,l+1,r-1));
    }
    public static void main(String[] args) {
        String str="dad";
        String ans=reverseString(str,0);
        System.out.println(ans);

        if(str.equals(ans)) System.out.println("Palindrome");
        else System.out.println("No Palindrome");

        boolean flag=isPal(str,0,str.length()-1);

        System.out.println(flag);
    }
}
