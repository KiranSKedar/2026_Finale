class Solution1{

    public int[][] transposeMatrix(int[][] mat){

        int n= mat.length;
        int m=mat[0].length;



        for(int i=0;i<n-1;i++){
            for(int j=i+1;j<n;j++){
               int temp=mat[i][j];
               mat[i][j]=mat[j][i];
               mat[j][i]=temp;
            }
        }

        return mat;
    }
}
