class Solution {
    public void moveZeroes(int[] nums) {

        int n=nums.length;


        for(int i=1;i<=n-1;i++){
            boolean flag=true;
            for(int j=0;j<=n-i-1;j++){
                if(nums[j]==0 && nums[j+1]!=0){
                    int temp=nums[j];
                    nums[j]=nums[j+1];
                    nums[j+1]=0;
                    flag=false;
                }
               
            }
             if(flag) return;
        }

        
    }
}
