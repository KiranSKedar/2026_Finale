https://leetcode.com/problems/squares-of-a-sorted-array/description/


class Solution {
    public void reverseArray(int[] arr){
        int n=arr.length;
        int i=0,j=n-1;

        while(i<=j){
            int temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            i++;
            j--;
        }
    }

    public int[] sortedSquares(int[] nums) {

        int n=nums.length;

        int i=0,j=n-1;
        int[] ans=new int[n];
        int k=0;

        while(i<=j){
            if(Math.abs(nums[i])>=Math.abs(nums[j])){
                ans[k++]=nums[i]*nums[i];
                i++;
            }else{
                ans[k++]=nums[j]*nums[j];
                j--;
            }
        }
        reverseArray(ans);

        return ans;


        
    }
}
