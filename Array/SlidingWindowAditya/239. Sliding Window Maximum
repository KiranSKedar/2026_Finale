https://leetcode.com/problems/sliding-window-maximum/

class Solution {
    public int[] maxSlidingWindow(int[] nums, int k) {

        int[] ans=new int[nums.length-k+1];

        int n=nums.length;

        Deque<Integer> q=new LinkedList<>();

        int i=0,j=0;

        while(j<n){
            if(q.isEmpty()){
                q.add(nums[j]);
            }else{

                while(!q.isEmpty() && q.peekLast()<nums[j]){
                    q.removeLast();
                }
                q.add(nums[j]);
            }

            if(j-i+1<k){
                j++;
            }else if(j-i+1==k){
                ans[i]=q.peek();

                if(q.peek()==nums[i]){
                    q.removeFirst();
                }
                i++;
                j++;
            }
        }

        return ans;
        
    }
}
