class Solution {
    public String minWindow(String s, String t) {

        int n=s.length();

        int m=t.length();

        Map<Character,Integer>mp=new HashMap<>();

        for(int i=0;i<m;i++){
            char ch=t.charAt(i);
            mp.put(ch,mp.getOrDefault(ch,0)+1);
        }

        int cnt=mp.size();

        int i=0,j=0;
        int start=0;
        int ans=Integer.MAX_VALUE;
        while(j<n){
            char c=s.charAt(j);
            if(mp.containsKey(c)){
                mp.put(c,mp.getOrDefault(c,0)-1);

                if(mp.get(c)==0)
                cnt--;
            }

            while(cnt==0){
                ans=Math.min(ans,j-i+1);
                start=i;

                char remove=s.charAt(i);
                if(mp.containsKey(remove)){
                    mp.put(remove,mp.getOrDefault(remove,0)+1);


                    if(mp.get(remove)==1)cnt++;
                }
                i++;
            }
            j++;
        }

        return ans==Integer.MAX_VALUE?"":s.substring(start,start+ans);
        
    }
}
