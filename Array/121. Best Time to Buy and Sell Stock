class Solution {
    public int maxProfit(int[] prices) {

        int n=prices.length;

        int mini=prices[0];
        int profit=Integer.MIN_VALUE;
        

        for(int i=0;i<n;i++){
            int cost=prices[i]-mini;
            profit=Integer.max(cost,profit);
            mini=Integer.min(mini,prices[i]);
                    }

                    return profit;
        
    }
}
