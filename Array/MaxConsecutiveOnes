class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n=nums.length;

        int ans=0;
    int cnt=0;
        for(int i=0;i<n;i++){
            
            if(nums[i]==1){
                cnt++;
            }else{
                 ans=Math.max(ans,cnt);
                 cnt=0;
            }
           
        }
        ans=Math.max(ans,cnt);
        return ans;
    }
}
